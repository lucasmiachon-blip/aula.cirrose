{
  "mcpServers": {
    "pubmed": {
      "command": "node",
      "args": ["scripts/run-pubmed-mcp.js"],
      "env": { "NCBI_API_KEY": "${NCBI_API_KEY}" }
    },
    "crossref": {
      "command": "npx",
      "args": ["-y", "@botanicastudios/crossref-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": { "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}" }
    },
    "google-scholar": {
      "command": "npx",
      "args": ["-y", "@JackKuo666/google-scholar-mcp-server"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECT_DIR}"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "${PROJECT_DIR}/.memory/context.jsonl" }
    },
    "eslint": {
      "command": "npx",
      "args": ["@eslint/mcp"]
    },
    "lighthouse": {
      "command": "npx",
      "args": ["@danielsogl/lighthouse-mcp"]
    },
    "a11y": {
      "command": "npx",
      "args": ["-y", "a11y-mcp-server"]
    },
    "sharp": {
      "command": "npx",
      "args": ["-y", "sharp-mcp"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": { "NOTION_TOKEN": "${NOTION_TOKEN}" }
    },
    "scite": {
      "type": "streamableHttp",
      "url": "https://api.scite.ai/mcp"
    },
    "ui-ux-pro": {
      "command": "npx",
      "args": ["-y", "ui-ux-pro-mcp"]
    },
    "frontend-review": {
      "command": "npx",
      "args": ["frontend-review-mcp"],
      "env": { "HYPERBOLIC_API_KEY": "${HYPERBOLIC_API_KEY}" }
    },
    "clinicaltrials": {
      "command": "npx",
      "args": ["-y", "clinicaltrialsgov-mcp-server"]
    },
    "design-comparison": {
      "command": "npx",
      "args": ["-y", "mcp-design-comparison"]
    },
    "page-design-guide": {
      "command": "npx",
      "args": ["-y", "page-design-guide-mcp"]
    },
    "floto": {
      "command": "npx",
      "args": ["@floto/mcp-server", "run"],
      "env": { "FLOTO_API_KEY": "${FLOTO_API_KEY}" }
    }
  }
}
