{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECT_DIR}"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "eslint": {
      "command": "npx",
      "args": ["@eslint/mcp"]
    },
    "lighthouse": {
      "command": "npx",
      "args": ["@danielsogl/lighthouse-mcp"]
    },
    "a11y": {
      "command": "npx",
      "args": ["-y", "a11y-mcp-server"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    },
    "a11y-contrast": {
      "command": "npx",
      "args": ["-y", "a11y-color-contrast-mcp"]
    },
    "gemini": {
      "command": "npx",
      "args": ["-y", "@fre4x/gemini"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "frontend-review": {
      "command": "npx",
      "args": ["frontend-review-mcp"],
      "env": {
        "HYPERBOLIC_API_KEY": "${HYPERBOLIC_API_KEY}"
      }
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-fetch"]
    },
    "sharp": {
      "command": "npx",
      "args": ["-y", "sharp-mcp"]
    },
    "a11y-contrast": {
      "command": "npx",
      "args": ["-y", "a11y-color-contrast-mcp"]
    },
    "gemini": {
      "command": "npx",
      "args": ["-y", "@fre4x/gemini"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "frontend-review": {
      "command": "npx",
      "args": ["frontend-review-mcp"],
      "env": {
        "HYPERBOLIC_API_KEY": "${HYPERBOLIC_API_KEY}"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"]
    }
  }
}
