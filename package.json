{
  "name": "aulas-magnas",
  "version": "7.0.0",
  "description": "Aulas magnas para congressos — deck.js + GSAP + OKLCH (grade/osteo: Reveal.js legacy)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:cirrose": "vite --open /aulas/cirrose/index.html",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "fonts:install": "node scripts/install-fonts.js",
    "lint:slides": "node scripts/lint-slides.js",
    "lint:case-sync": "node scripts/lint-case-sync.js",
    "lint:narrative-sync": "node scripts/lint-narrative-sync.js",
    "lint:gsap-race": "node scripts/lint-gsap-css-race.mjs",
    "export:pdf": "node scripts/export-pdf.js",
    "qa:a11y": "node scripts/qa-accessibility.js",
    "qa:screenshots:cirrose": "node aulas/cirrose/scripts/qa-batch-screenshot.mjs",
    "qa:video": "node scripts/qa/qa-video.js",
    "build:cirrose": "powershell -ExecutionPolicy Bypass -File aulas/cirrose/scripts/build-html.ps1",
    "zip:ia": "./scripts/build-zip-limpo-ia.ps1",
    "done:cirrose": "node scripts/done-gate.js cirrose",
    "done:cirrose:strict": "node scripts/done-gate.js cirrose --strict",
    "mcp:dev": "node scripts/mcp-switch.js dev",
    "mcp:research": "node scripts/mcp-switch.js research",
    "mcp:qa": "node scripts/mcp-switch.js qa",
    "mcp:full": "node scripts/mcp-switch.js full",
    "research:cirrose": "node aulas/cirrose/scripts/content-research.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@notionhq/client": "^2.3.0",
    "axe-core": "^4.11.1",
    "decktape": "^3.14.0",
    "dotenv": "^16.4.0",
    "playwright": "^1.58.2",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  }
}
